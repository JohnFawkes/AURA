        "config.Config_Notification_Pushover": {
            "type": "object",
            "properties": {
                "api_token": {
                    "description": "Token for the Pushover notification provider.",
                    "type": "string"
                },
                "user_key": {
                    "description": "UserKey for the Pushover notification provider.",
                    "type": "string"
                }

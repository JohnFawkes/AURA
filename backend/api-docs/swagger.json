        "models.MediaItem": {
            "type": "object",
            "properties": {
                "added_at": {
                    "description": "Added timestamp",
                    "type": "integer"
                },
                "collection_ids": {
                    "description": "IDs of collections this item belongs to",
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "content_rating": {
                    "description": "Used in MediaItem Details Page - For more information about the item",
                    "type": "string"
                },
                "db_saved_sets": {
                    "description": "Used in MediaItem Details Page - For poster sets",

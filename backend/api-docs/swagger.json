        "config.Config_SonarrRadarrApp": {
            "type": "object",
            "properties": {
                "api_token": {
                    "description": "API key for accessing the Sonarr/Radarr server.",
                    "type": "string"
                },
                "library": {
                    "description": "Name of the Media Server library associated with this Sonarr/Radarr instance.",
                    "type": "string"

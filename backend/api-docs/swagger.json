                "guids": {
                    "description": "Used in MediaItem Details Page - For ratings",
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/models.MediaItemGuid"
                    }
                },
                "has_mediux_sets": {
                    "description": "Used in Home Page - sorting and filtering",
